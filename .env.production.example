# Production environment template
OPENAI_API_KEY=sk-...
PORT=8787

# Public origins/domains
APP_PUBLIC_BASE_URL=https://api.yourdomain.com
APP_WIDGET_DOMAIN=https://widgets.yourdomain.com
MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://chatgpt.com
MCP_ALLOWED_HOSTS=api.yourdomain.com

# Consent and account binding
REQUIRE_LEGAL_CONSENT=true
AUTO_ACCEPT_LEGAL_CONSENT=true
REQUIRE_OAUTH_ACCOUNT_BINDING=true
AUTH_VERIFY_JWT=true

# OAuth/JWT verification
OAUTH_JWKS_URI=https://auth.yourdomain.com/.well-known/jwks.json
OAUTH_ISSUER=https://auth.yourdomain.com/
OAUTH_AUDIENCE=https://api.yourdomain.com
OAUTH_AUTHORIZATION_SERVERS=https://auth.yourdomain.com/
OAUTH_REQUIRED_SCOPES=companion.read,companion.write,media.generate,screen.read

# Models
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_VIDEO_MODEL=sora
OPENAI_TTS_DEFAULT_VOICE=alloy
