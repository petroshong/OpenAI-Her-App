OPENAI_API_KEY=sk-...
PORT=8787
APP_PUBLIC_BASE_URL=https://your-app.example.com
APP_WIDGET_DOMAIN=https://your-unique-widget.example.com
MCP_ALLOWED_ORIGINS=https://chat.openai.com,https://chatgpt.com
MCP_ALLOWED_HOSTS=your-app.example.com
REQUIRE_LEGAL_CONSENT=true
AUTO_ACCEPT_LEGAL_CONSENT=true
AUTO_FIRST_TURN_MEDIA=true
REQUIRE_OAUTH_ACCOUNT_BINDING=true
AUTH_VERIFY_JWT=true
OAUTH_JWKS_URI=https://your-auth.example.com/.well-known/jwks.json
OAUTH_ISSUER=https://your-auth.example.com/
OAUTH_AUDIENCE=https://your-app.example.com
OAUTH_AUTHORIZATION_SERVERS=https://your-auth.example.com/
OAUTH_REQUIRED_SCOPES=companion.read,companion.write,media.generate,screen.read
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_VIDEO_MODEL=sora
OPENAI_TTS_DEFAULT_VOICE=alloy
